# The Council capstone uses offline fixture mode by default.
# You do not need any API keys for:
#   npm run demo:fixture
#   npm test
#   npm run mcp:stub

PORT=3001

# Optional live-provider mode only.
# Leave these unset for the public capstone demo.
ANTHROPIC_API_KEY=replace_with_your_own_key
OPENAI_API_KEY=replace_with_your_own_key
GOOGLE_API_KEY=replace_with_your_own_key
XAI_API_KEY=replace_with_your_own_key
BRAVE_SEARCH_API_KEY=replace_with_your_own_key

# Optional live-mode resilience tuning (safe defaults shown).
# API_TIMEOUT_MS=60000          # per provider call timeout
# API_SEARCH_TIMEOUT_MS=90000   # per web-search provider call timeout
# API_RETRIES=2                 # retry attempts on transient (429/5xx/network) failures
# SHADOW_COUNCIL_URL=http://localhost:3002
