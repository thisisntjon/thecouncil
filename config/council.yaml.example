# Copy this file to config/council.yaml and adjust as needed.

models:
  claude-sonnet:
    provider: anthropic
    model: claude-sonnet-4-6
    api_key_env: ANTHROPIC_API_KEY
    params:
      temperature: 0.65
      max_tokens: 2048
  gpt-5:
    provider: openai
    model: gpt-5.2
    api_key_env: OPENAI_API_KEY
    params:
      temperature: 0.6
      max_tokens: 2048
  gemini-3-flash:
    provider: gemini
    model: gemini-3-flash-preview
    api_key_env: GOOGLE_API_KEY
    params:
      temperature: 0.45
      max_tokens: 2048
  grok-4:
    provider: xai
    model: grok-4-1-fast-reasoning
    api_key_env: XAI_API_KEY
    params:
      temperature: 0.55
      max_tokens: 2048
  # Optional additional models:
  # qwen-plus:
  #   provider: openai
  #   model: qwen-plus
  #   api_key_env: QWEN_API_KEY
  #   params:
  #     temperature: 0.7
  #     max_tokens: 900
  # mixtral-8x7b:
  #   provider: huggingface
  #   model: mistralai/Mixtral-8x7B-Instruct-v0.1
  #   api_key_env: HUGGINGFACE_API_KEY
  #   params:
  #     max_new_tokens: 650
  #     temperature: 0.6

council:
  members:
    - claude-sonnet
    - gpt-5
    - gemini-3-flash
    - grok-4
  rater: gpt-5
  synthesizer: gpt-5
